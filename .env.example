# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/scout_panel"

# Postgres service credentials (used by docker-compose db service)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="123456"
POSTGRES_DB="postgres"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET="change_me_in_production"

# ── Backend ───────────────────────────────────────────────────────────────────
PORT="4000"
NODE_ENV="development"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes exactos permitidos (separados por coma)
ALLOWED_ORIGINS="http://localhost:3000,https://scout-panel-ldp.vercel.app"

# Patrones regex para orígenes dinámicos (Vercel preview branches).
# Cubre: scout-panel-ldp-git-<branch>-<user>.vercel.app y scout-panel-ldp-<hash>-<user>.vercel.app
ALLOWED_ORIGIN_PATTERNS="https://scout-panel-ldp.*\.vercel\.app"

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL pública del backend que el navegador usa para llamar a la API.
# En producción cambiarlo a la URL real (ej. Render):
#   NEXT_PUBLIC_API_URL="https://scout-panel-api.onrender.com/api"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# ── URLs de producción (usadas solo en el startup log del backend) ────────────
# En producción reemplazar con las URLs reales de Render y Vercel.
BACKEND_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"
