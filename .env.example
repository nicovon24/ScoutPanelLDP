# ─────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────
# Local (drizzle migrate, backend en dev): obligatoria
DEV_DATABASE_URL=postgresql://scout:scout1234@localhost:5433/scout_panel
# Producción (NODE_ENV=production)
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Ya no usás solo esto para migrar / pool en dev (usan DEV_DATABASE_URL arriba).
# El servicio backend en Docker sí recibe DATABASE_URL desde docker-compose.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/scout_panel
# Local Docker (puerto host si mapeás 5432): postgresql://scout:scout1234@localhost:5432/scout_panel

# Opcional: solo si querés sobreescribir los defaults del docker-compose (scout / scout1234 / scout_panel)
# DEV_POSTGRES_USER=scout
# DEV_POSTGRES_PASSWORD=scout1234
# DEV_POSTGRES_DB=scout_panel

# ─────────────────────────────────────────────────────────────────
# BACKEND
# ─────────────────────────────────────────────────────────────────
PORT=4000
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
NODE_ENV=development   # development | production

# ─────────────────────────────────────────────────────────────────
# FRONTEND (Next.js — variables públicas)
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
# Producción: https://your-backend.up.railway.app
