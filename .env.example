# ─────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/scout_panel
# Local Docker:  postgresql://scout:scout1234@localhost:5432/scout_panel
# Supabase prod: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

POSTGRES_USER=scout
POSTGRES_PASSWORD=scout1234
POSTGRES_DB=scout_panel

# ─────────────────────────────────────────────────────────────────
# BACKEND
# ─────────────────────────────────────────────────────────────────
PORT=4000
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
NODE_ENV=development   # development | production

# ─────────────────────────────────────────────────────────────────
# FRONTEND (Next.js — variables públicas)
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
# Producción: https://your-backend.up.railway.app
