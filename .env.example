# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://scout:scout1234@localhost:5432/scout_panel

# Postgres service credentials (used by docker-compose db service)
POSTGRES_USER=scout
POSTGRES_PASSWORD=scout1234
POSTGRES_DB=scout_panel

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=change_me_in_production

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Origins allowed by CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
