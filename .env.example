# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/scout_panel"

# Postgres service credentials (used by docker-compose db service)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="123456"
POSTGRES_DB="postgres"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET="change_me_in_production"
JWT_SECRET_REFRESH="change_me_refresh_secret"
JWT_EXPIRATION_ACCESS="15m"
JWT_EXPIRATION_REFRESH="7d"

# ── Backend ───────────────────────────────────────────────────────────────────
PORT="4000"
NODE_ENV="development"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes exactos permitidos (separados por coma)
ALLOWED_ORIGINS="http://localhost:3000,https://scout-panel-ldp.vercel.app"

# Patrones regex para orígenes dinámicos (Vercel preview branches).
# Cubre: scout-panel-ldp-git-<branch>-<user>.vercel.app y scout-panel-ldp-<hash>-<user>.vercel.app
ALLOWED_ORIGIN_PATTERNS="https://scout-panel-ldp.*\.vercel\.app"

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL pública del backend que el navegador usa para llamar a la API.
# En producción se recomienda "/api" + BACKEND_PROXY_URL (evita cookies third-party en Safari/incógnito).
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# URL real del backend para el rewrite de Next (servidor a servidor).
# Ejemplo prod: https://tu-api.onrender.com
BACKEND_PROXY_URL=""

# Solo para casos excepcionales:
# si está en "true", el frontend permite usar NEXT_PUBLIC_API_URL cross-origin en producción. Esto puede romper persistencia de cookies en Safari/Incógnito.
NEXT_PUBLIC_ALLOW_CROSS_ORIGIN_API="false"

# ── URLs solo para los logs de producción (usadas solo en el startup log del backend) ────────────
BACKEND_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"
